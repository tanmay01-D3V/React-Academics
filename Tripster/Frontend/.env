# Copy this file to .env.local (or .env) and fill values. Do NOT commit your real keys.
# For Vite, environment variables used in client code must start with VITE_
VITE_RAPIDAPI_KEY=your_rapidapi_key_here
VITE_RAPIDAPI_HOST=booking-com15.p.rapidapi.com
VITE_BOOKING_BASE_URL=https://booking-com15.p.rapidapi.com/api/v1/cars/searchCarRentals
# Optional defaults if you don't have geocoded coordinates readily available
VITE_DEFAULT_LATITUDE=40.6397018432617
VITE_DEFAULT_LONGITUDE=-73.7791976928711
VITE_IMAGE_SEARCH_KEY=your_image_search_key_here
VITE_IMAGE_SEARCH_HOST=google-search-master-mega.p.rapidapi.com
